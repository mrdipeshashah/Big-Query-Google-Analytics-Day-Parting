WITH base_data AS (
    SELECT
        PARSE_DATE('%Y%m%d', event_date) AS _date,
        -- FIX: Use COALESCE to fallback to 0 if the timezone offset is NULL
        TIMESTAMP_ADD(TIMESTAMP_MICROS(event_timestamp), INTERVAL COALESCE(device.time_zone_offset_seconds, 0) SECOND) AS local_timestamp,
        geo.country AS country,
        geo.region AS region,
        event_name,
        user_pseudo_id,
        (SELECT value.int_value FROM UNNEST(event_params) WHERE key = 'ga_session_id') AS session_id,
        ecommerce.purchase_revenue
    FROM `enter.tablename_123456.events_*`
    WHERE _TABLE_SUFFIX BETWEEN '20250101' AND '20250331'
)

SELECT
    _date AS date,
    country,
    region,
    EXTRACT(MONTH FROM _date) AS month,
    EXTRACT(YEAR FROM _date) AS year,
    EXTRACT(WEEK FROM _date) AS week_no_of_year,
    FORMAT_DATE('%A', _date) AS day_of_week,
    EXTRACT(HOUR FROM local_timestamp) AS hour,
    CASE
        WHEN EXTRACT(HOUR FROM local_timestamp) BETWEEN 0 AND 3 THEN 'Lates'
        WHEN EXTRACT(HOUR FROM local_timestamp) BETWEEN 4 AND 5 THEN 'Early Risers'
        WHEN EXTRACT(HOUR FROM local_timestamp) BETWEEN 6 AND 8 THEN 'Breakfast'
        WHEN EXTRACT(HOUR FROM local_timestamp) BETWEEN 9 AND 11 THEN 'Morning'
        WHEN EXTRACT(HOUR FROM local_timestamp) BETWEEN 12 AND 13 THEN 'Lunchtime'
        WHEN EXTRACT(HOUR FROM local_timestamp) BETWEEN 14 AND 16 THEN 'Afternoon'
        WHEN EXTRACT(HOUR FROM local_timestamp) BETWEEN 17 AND 19 THEN 'Early Evening'
        ELSE 'Evening' 
    END AS day_part,
    COUNT(DISTINCT CONCAT(user_pseudo_id, CAST(session_id AS STRING))) AS sessions,
    COUNTIF(event_name = 'add_to_cart') AS adds_to_cart,
    COUNTIF(event_name = 'view_item') AS views,
    COUNTIF(event_name = 'purchase') AS purchases,
    SUM(IF(event_name = 'purchase', purchase_revenue, 0)) AS total_revenue
FROM base_data
GROUP BY 1, 2, 3, 4, 5, 6, 7, 8, 9
ORDER BY date DESC, hour ASC
